import numpy as np
import pandas as pd
import matplotlib.pyplot as plt
from sklearn.linear_model import LinearRegression

np.random.seed(42)

n = 100

# Simulate shots (independent variable)
shots = np.random.randint(20, 50, n)

# Simulate goals (dependent variable)
# Assume: more shots → more goals + some randomness
goals = 0.1 * shots + np.random.normal(0, 1.5, n)

# Create DataFrame
df = pd.DataFrame({
    "shots": shots,
    "goals": goals
})

print(df.head())

X = df[["shots"]]
y = df["goals"]

model = LinearRegression()
model.fit(X, y)

print("Slope:", model.coef_[0])
print("Intercept:", model.intercept_)

plt.figure(figsize=(8,6))

plt.scatter(df["shots"], df["goals"])

# regression line
plt.plot(df["shots"], model.predict(X))

plt.xlabel("Shots")
plt.ylabel("Goals")
plt.title("NHL Data: Shots vs Goals")
plt.savefig("nhl.png")
plt.show()


